{
  "name": "real-time-chat",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "cross-env FRONTEND_ORIGIN=http://localhost:5273 npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "start": "npm --workspace backend start",
    "build": "npm --workspace frontend run build",
    "test": "npm --workspace backend test && npm --workspace frontend run build"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "npm-run-all": "^4.1.5"
  }
}
